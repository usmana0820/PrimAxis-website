rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    // Admin profiles — sign-up creates own doc; developer activates in Console
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update, delete: if false;
    }

    match /projects/{projectId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin()
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'developer';
    }

    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
