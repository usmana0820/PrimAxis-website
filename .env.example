# Firebase (Spark / free tier) — https://console.firebase.google.com
# Copy this file to .env.local and fill in your project values.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Cloudinary (optional — image CDN uploads)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Web3Forms (optional — email you when someone submits the contact form)
# Free at https://web3forms.com — use the same inbox as CONTACT_EMAIL
VITE_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key
